# Azure IoT Hub Device Connection String for NAC sensor
# Get this from: Azure Portal → IoT Hub → Devices → nac-sensor → Primary Connection String
IOTHUB_DEVICE_CONNECTION_STRING="HostName=<your-iothub-name>.azure-devices.net;DeviceId=nac-sensor;SharedAccessKey=<your-shared-access-key>"

# Location of the sensor for data field enrichment
LOCATION="nac"
