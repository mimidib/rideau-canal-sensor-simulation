# Azure IoT Hub Device Connection String for Dow's Lake sensor
# Get this from: Azure Portal → IoT Hub → Devices → dows-lake-sensor → Primary Connection String
IOTHUB_DEVICE_CONNECTION_STRING="HostName=<your-iothub-name>.azure-devices.net;DeviceId=dows-lake-sensor;SharedAccessKey=<your-shared-access-key>"

# Location of the sensor for data field enrichment
LOCATION="dows-lake"
