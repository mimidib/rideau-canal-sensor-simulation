# Azure IoT Hub Device Connection String for Fifth Avenue sensor
# Get this from: Azure Portal → IoT Hub → Devices → fifth-avenue-sensor → Primary Connection String
IOTHUB_DEVICE_CONNECTION_STRING="HostName=<your-iothub-name>.azure-devices.net;DeviceId=fifth-avenue-sensor;SharedAccessKey=<your-shared-access-key>"

# Location of the sensor for data field enrichment
LOCATION="fifth-avenue"
